# API
API_BASE_URL=http://localhost:3000/api/v1
API_KEY=headless-service-key

# Bull Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Puppeteer
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# 2Captcha
CAPTCHA_API_KEY=
CAPTCHA_BASE_URL=https://2captcha.com
CAPTCHA_TIMEOUT=120

# Proxy Rotation
PROXY_LIST=
PROXY_ROTATION_INTERVAL=60000

# Browser Pool
BROWSER_POOL_MIN=1
BROWSER_POOL_MAX=5

# Queue
SUBMISSION_QUEUE_CONCURRENCY=2
RESULT_QUEUE_CONCURRENCY=5

# Logging
LOG_LEVEL=info
