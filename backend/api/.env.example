# ============================================
# قرعة - Qor3a Backend Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qor3a
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=false

# CORS
CORS_ORIGIN=http://localhost:5173

# AI Service
AI_SERVICE_URL=http://localhost:8000

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v17.0

# MinIO / S3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Encryption
# Generate a strong key: openssl rand -hex 32
ENCRYPTION_KEY=change-this-to-a-32-char-string-for-aes-256

# File-level encryption (AES-256-GCM, requires ENCRYPTION_KEY)
# WARNING: enabling this will break direct static file serving
FILE_ENCRYPTION_ENABLED=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 2Captcha
CAPTCHA_API_KEY=
