# ============================================
# قرعة - qor3a Environment Configuration
# ============================================
# Copy this file to .env and adjust values

# --- General ---
NODE_ENV=development
APP_NAME=qor3a
API_VERSION=v1

# --- Database (PostgreSQL / Supabase) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qor3a
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --- AI Service ---
AI_SERVICE_URL=http://ai-service:8000
AI_MAX_IMAGE_SIZE_MB=10
AI_VALIDATION_TIMEOUT_MS=10000

# --- Headless Browser Service ---
HEADLESS_SERVICE_URL=http://headless-service:3001
CAPTCHA_API_KEY=your-2captcha-api-key
PROXY_POOL=http://proxy1:port,http://proxy2:port
HEADLESS_CONCURRENCY=5
HEADLESS_DELAY_MS=3000

# --- Storage (S3/MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=qor3a-photos

# --- Notifications ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_API_URL=https://api.whatsapp.com/v1

# --- Encryption ---
ENCRYPTION_KEY=change-this-to-a-256-bit-random-key

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Server ---
PORT=3000
HOST=0.0.0.0
